<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xiaomi</title>
    <link rel="icon" href="https://www.mi.com/favicon.ico" type="image/x-icon">
    <style>
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 20px;
            background: #fff;
        }

        .left-menu, .right-menu {
            display: flex;
            gap: 20px;
            list-style: none;
        }

        ul {
            margin: 0;
            padding: 0;
        }

        li {
            display: inline;
            cursor: pointer;
        }

        .container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            padding: 20px;
        }

        .card {
            border: 1px solid #ccc;
            border-radius: 10px;
            background: #fff;
            padding: 15px;
            text-align: center;
            box-shadow: 0px 4px 6px rgba(0,0,0,0.1);
            transition: transform 0.2s ease;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card img {
            max-width: 100%;
            height: auto;
        }

        .card h3 {
            font-size: 16px;
            margin: 10px 0 5px;
        }

        .card p {
            font-size: 14px;
            color: #555;
        }
    </style>
</head>
<body>

<nav>
    <ul class="left-menu">
        <img src="https://www.mi.com/favicon.ico" alt="Xiaomi Logo" style="height: 30px;">
        <li>Store</li>
        <li>Phone</li>
        <li>Tablets</li>
        <li>TV & Smart Home</li>
        <li>Smart Watch & Audio</li>
    </ul>
    
    <ul class="right-menu">
        <li>Discover</li>
        <li>Support</li>
        <li>Search</li>
        <li>Sign up</li>
    </ul>
</nav>

<div class="container">
    <div class="card">
        <img src="https://i03.appmifile.com/586_operator_in/27/05/2025/5381642f8863692241876d9a10b76a88.png?thumb=1&w=220&f=webp&q=85" alt="Mi 11 Ultra">
        <h3>Mi 11 Ultra</h3>
        <p>Flagship Performance | AMOLED Display</p>
    </div>

    <div class="card">
        <img src="https://i03.appmifile.com/586_operator_in/27/05/2025/5381642f8863692241876d9a10b76a88.png?thumb=1&w=220&f=webp&q=85" alt="Mi 11 Ultra">
        <h3>Mi 11 Ultra</h3>
        <p>Flagship Performance | AMOLED Display</p>
    </div>

    <div class="card">
        <img src="https://i03.appmifile.com/586_operator_in/27/05/2025/5381642f8863692241876d9a10b76a88.png?thumb=1&w=220&f=webp&q=85" alt="Mi 11 Ultra">
        <h3>Mi 11 Ultra</h3>
        <p>Flagship Performance | AMOLED Display</p>
    </div>

    <!-- Add more cards as needed -->
</div>

</body>
</html>
